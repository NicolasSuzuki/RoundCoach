generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MatchResult {
  WIN
  LOSS
}

enum VodStatus {
  UPLOADED
  PROCESSING
  PROCESSED
  FAILED
}

enum AnalysisProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum TrainingPlanStatus {
  ACTIVE
  ARCHIVED
  SUPERSEDED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  currentRank  String?
  targetRank   String?
  currentGoal  String?
  mainAgents   String[]
  mainRole     String?
  currentFocus String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  matches       Match[]
  vods          Vod[]
  trainingPlans TrainingPlan[]
  dashboardSummarySnapshot DashboardSummarySnapshot?
}

model Match {
  id             String      @id @default(cuid())
  userId         String
  map            String
  agent          String
  result         MatchResult
  score          String
  matchDate      DateTime
  notes          String?
  externalSource String?
  externalId     String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vod      Vod?
  analysis Analysis?
  importedSnapshot ImportedMatchSnapshot?
  scoreboardPlayers MatchScoreboardPlayer[]

  @@index([userId])
  @@index([matchDate])
  @@unique([userId, externalSource, externalId])
}

model ImportedMatchSnapshot {
  id              String   @id @default(cuid())
  matchId         String   @unique
  externalSource  String
  externalId      String
  queueId         String?
  durationSeconds Int?
  rawJson         Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([externalSource, externalId])
}

model MatchScoreboardPlayer {
  id                 String   @id @default(cuid())
  matchId            String
  puuid              String?
  isCurrentUser      Boolean  @default(false)
  gameName           String
  tagLine            String?
  teamId             String
  agent              String
  competitiveTier    Int?
  kills              Int
  deaths             Int
  assists            Int
  score              Int
  acs                Float
  adr                Float?
  headshotPercentage Float?
  kastPercentage     Float?
  firstKills         Int
  firstDeaths        Int
  multiKills         Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([puuid])
}

model Vod {
  id              String    @id @default(cuid())
  userId          String
  matchId         String?   @unique
  fileName        String
  fileUrl         String
  storagePath     String?
  durationSeconds Int?
  status          VodStatus @default(UPLOADED)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  match    Match?    @relation(fields: [matchId], references: [id], onDelete: SetNull)
  analysis Analysis?

  @@index([userId])
  @@index([status])
}

model Analysis {
  id                  String                   @id @default(cuid())
  matchId             String                   @unique
  vodId               String?                  @unique
  processingStatus    AnalysisProcessingStatus @default(PENDING)
  deathsFirst         Int?
  entryKills          Int?
  avgCrosshairScore   Float?
  utilityUsageScore   Float?
  positioningScore    Float?
  summary             String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  vod   Vod?  @relation(fields: [vodId], references: [id], onDelete: SetNull)

  @@index([processingStatus])
}

model TrainingPlan {
  id                 String             @id @default(cuid())
  userId             String
  status             TrainingPlanStatus @default(ACTIVE)
  generatedFromRange String?
  mainWeakness       String
  mainStrength       String
  focusArea          String
  priority           String
  trend              String
  intensity          String
  dailyPlanJson      Json
  weeklyPlanJson     Json
  microGoal          String
  justification      String
  version            Int                @default(1)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([createdAt])
}

model DashboardSummarySnapshot {
  id        String   @id @default(cuid())
  userId    String   @unique
  signature String
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
}
